{
	echo "Configuring Dovecot AUTH Settings"
	sed -i "s#{{ MDA_AUTH_LISTEN }}#$MDA_AUTH_LISTEN#g" $MDA_CONF_ENV
	sed -i "s#{{ MDA_AUTH_PORT }}#$MDA_AUTH_PORT#g" $MDA_CONF_ENV
	sed -i "s#{{ MDA_AUTH_TLS }}#$MDA_AUTH_TLS#g" $MDA_CONF_ENV
	sed -i "s#{{ MDA_AUTH_TRUST_NET }}#$MDA_AUTH_TRUST_NET#g" $MDA_CONF_ENV
}

if [ "$1" = "configure" ]; then
#  CONFFILES="dovecot.conf \
