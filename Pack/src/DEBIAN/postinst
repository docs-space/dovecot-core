	#Linking
	ln -sf /opt/r7-mailserver/mdaserver/bin/* /bin

	echo "Checking existing Dovecot configuration files"
	for CONFFILE in $MDA_CONF_DIR/conf.d/*.conf $MDA_CONF_DIR/*.conf
    do
        chmod 0640 "$CONFFILE"
      	chgrp dovecot "$CONFFILE"
    done

  	#for conffile in $CONFFILES ; do
    # Tell ucf that the file in /opt/dovecot/usr/share/dovecot is the latest
    # maintainer version, and let it handle how to manage the real
